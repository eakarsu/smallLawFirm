generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTHENTICATION & USERS ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  role          UserRole  @default(ATTORNEY)
  phone         String?
  barNumber     String?
  department    String?
  hourlyRate    Decimal?  @db.Decimal(10, 2)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  matters           Matter[]
  timeEntries       TimeEntry[]
  tasks             Task[]
  calendarEvents    CalendarEvent[]
  documents         Document[]
  messages          Message[]
  callLogs          CallLog[]
  aiRequests        AIRequest[]
  notifications     Notification[]
  assignedTasks     Task[]          @relation("TaskAssignee")
  createdClients    Client[]        @relation("ClientCreator")

  @@map("users")
}

enum UserRole {
  ADMIN
  PARTNER
  ATTORNEY
  PARALEGAL
  SECRETARY
  BILLING
}

// ==================== CLIENTS & MATTERS ====================

model Client {
  id              String       @id @default(cuid())
  clientNumber    String       @unique
  type            ClientType   @default(INDIVIDUAL)
  status          ClientStatus @default(ACTIVE)

  // Individual fields
  firstName       String?
  lastName        String?
  middleName      String?

  // Company fields
  companyName     String?

  // Contact info
  email           String?
  phone           String?
  mobile          String?
  fax             String?

  // Address
  address         String?
  city            String?
  state           String?
  zipCode         String?
  country         String?

  // Billing
  billingRate     Decimal?     @db.Decimal(10, 2)
  billingMethod   BillingMethod @default(HOURLY)

  // Portal access
  portalEnabled   Boolean      @default(false)
  portalPassword  String?

  // Dates
  intakeDate      DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  createdById     String
  createdBy       User         @relation("ClientCreator", fields: [createdById], references: [id])
  matters         Matter[]
  contacts        ClientContact[]
  conflicts       ConflictCheck[]
  documents       Document[]
  messages        Message[]
  invoices        Invoice[]
  payments        Payment[]
  intakeSubmissions ClientIntake[]

  @@map("clients")
}

enum ClientType {
  INDIVIDUAL
  COMPANY
  GOVERNMENT
  NON_PROFIT
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECTIVE
  FORMER
}

enum BillingMethod {
  HOURLY
  FLAT_FEE
  CONTINGENCY
  RETAINER
  PRO_BONO
}

model ClientContact {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  title       String?
  email       String?
  phone       String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("client_contacts")
}

model ClientIntake {
  id              String       @id @default(cuid())
  clientId        String?
  client          Client?      @relation(fields: [clientId], references: [id])
  status          IntakeStatus @default(PENDING)
  source          String?

  // Intake form data (JSON)
  formData        Json

  // AI processing
  aiProcessed     Boolean      @default(false)
  aiSummary       String?
  aiRecommendations String?

  submittedAt     DateTime     @default(now())
  processedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("client_intakes")
}

enum IntakeStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
  CONVERTED
}

model Matter {
  id              String       @id @default(cuid())
  matterNumber    String       @unique
  name            String
  description     String?

  clientId        String
  client          Client       @relation(fields: [clientId], references: [id])

  leadAttorneyId  String
  leadAttorney    User         @relation(fields: [leadAttorneyId], references: [id])

  caseType        CaseType
  status          MatterStatus @default(OPEN)
  priority        Priority     @default(MEDIUM)

  // Court info
  courtName       String?
  caseNumber      String?
  judge           String?
  courtroom       String?

  // Dates
  openDate        DateTime     @default(now())
  closeDate       DateTime?
  statuteOfLimitations DateTime?

  // Billing
  billingMethod   BillingMethod @default(HOURLY)
  flatFeeAmount   Decimal?     @db.Decimal(10, 2)
  contingencyPercent Decimal?  @db.Decimal(5, 2)
  estimatedValue  Decimal?     @db.Decimal(15, 2)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  relatedMatters  Matter[]     @relation("RelatedMatters")
  relatedTo       Matter[]     @relation("RelatedMatters")
  documents       Document[]
  timeEntries     TimeEntry[]
  expenses        Expense[]
  tasks           Task[]
  calendarEvents  CalendarEvent[]
  deadlines       Deadline[]
  courtFilings    CourtFiling[]
  invoices        Invoice[]
  conflicts       ConflictCheck[]
  notes           MatterNote[]
  aiRequests      AIRequest[]

  @@map("matters")
}

model MatterNote {
  id          String   @id @default(cuid())
  matterId    String
  matter      Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("matter_notes")
}

enum CaseType {
  CIVIL_LITIGATION
  CRIMINAL_DEFENSE
  FAMILY_LAW
  REAL_ESTATE
  CORPORATE
  INTELLECTUAL_PROPERTY
  BANKRUPTCY
  EMPLOYMENT
  IMMIGRATION
  PERSONAL_INJURY
  ESTATE_PLANNING
  TAX
  ENVIRONMENTAL
  OTHER
}

enum MatterStatus {
  OPEN
  PENDING
  ON_HOLD
  CLOSED
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model ConflictCheck {
  id          String        @id @default(cuid())
  matterId    String?
  matter      Matter?       @relation(fields: [matterId], references: [id])
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id])

  searchTerms String
  status      ConflictStatus @default(PENDING)
  result      ConflictResult?
  details     String?

  // AI conflict check
  aiChecked   Boolean       @default(false)
  aiFindings  String?

  checkedAt   DateTime      @default(now())
  resolvedAt  DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("conflict_checks")
}

enum ConflictStatus {
  PENDING
  CLEARED
  CONFLICT_FOUND
  WAIVED
}

enum ConflictResult {
  NO_CONFLICT
  POTENTIAL_CONFLICT
  DEFINITE_CONFLICT
}

// ==================== DOCUMENT MANAGEMENT ====================

model Document {
  id              String         @id @default(cuid())
  name            String
  description     String?
  fileName        String
  fileType        String
  fileSize        Int
  filePath        String

  matterId        String?
  matter          Matter?        @relation(fields: [matterId], references: [id])
  clientId        String?
  client          Client?        @relation(fields: [clientId], references: [id])
  uploadedById    String
  uploadedBy      User           @relation(fields: [uploadedById], references: [id])

  category        DocumentCategory @default(OTHER)
  status          DocumentStatus   @default(DRAFT)

  // Version control
  version         Int              @default(1)
  parentId        String?
  parent          Document?        @relation("DocumentVersions", fields: [parentId], references: [id])
  versions        Document[]       @relation("DocumentVersions")

  // E-signature
  signatureRequired Boolean        @default(false)
  signatureStatus   SignatureStatus?
  signedAt        DateTime?
  signedBy        String?

  // Bates numbering
  batesPrefix     String?
  batesStart      Int?
  batesEnd        Int?

  // Redaction
  isRedacted      Boolean          @default(false)
  redactedPath    String?

  // AI features
  aiSummary       String?
  aiKeyPoints     String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("documents")
}

enum DocumentCategory {
  PLEADING
  MOTION
  BRIEF
  CONTRACT
  CORRESPONDENCE
  DISCOVERY
  EVIDENCE
  COURT_ORDER
  TRANSCRIPT
  TEMPLATE
  CLIENT_FILE
  BILLING
  OTHER
}

enum DocumentStatus {
  DRAFT
  FINAL
  EXECUTED
  FILED
  ARCHIVED
}

enum SignatureStatus {
  PENDING
  SIGNED
  DECLINED
  EXPIRED
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    DocumentCategory
  content     String   @db.Text
  variables   Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("document_templates")
}

// ==================== CALENDAR & DEADLINES ====================

model CalendarEvent {
  id              String        @id @default(cuid())
  title           String
  description     String?

  matterId        String?
  matter          Matter?       @relation(fields: [matterId], references: [id])
  userId          String
  user            User          @relation(fields: [userId], references: [id])

  eventType       EventType     @default(MEETING)
  location        String?

  startTime       DateTime
  endTime         DateTime
  allDay          Boolean       @default(false)

  isRecurring     Boolean       @default(false)
  recurrenceRule  String?

  reminderMinutes Int?
  reminderSent    Boolean       @default(false)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("calendar_events")
}

enum EventType {
  MEETING
  COURT_DATE
  DEPOSITION
  HEARING
  TRIAL
  DEADLINE
  REMINDER
  CONFERENCE_CALL
  CLIENT_MEETING
  OTHER
}

model Deadline {
  id              String         @id @default(cuid())
  title           String
  description     String?

  matterId        String
  matter          Matter         @relation(fields: [matterId], references: [id])

  deadlineType    DeadlineType
  dueDate         DateTime

  courtRuleId     String?
  courtRule       CourtRule?     @relation(fields: [courtRuleId], references: [id])

  status          DeadlineStatus @default(PENDING)
  completedAt     DateTime?

  // AI calculated
  aiCalculated    Boolean        @default(false)
  aiNotes         String?

  reminderDays    Int            @default(7)
  reminderSent    Boolean        @default(false)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("deadlines")
}

enum DeadlineType {
  FILING
  RESPONSE
  DISCOVERY
  MOTION
  STATUTE_OF_LIMITATIONS
  APPEAL
  COURT_DATE
  OTHER
}

enum DeadlineStatus {
  PENDING
  COMPLETED
  OVERDUE
  EXTENDED
  CANCELLED
}

model CourtRule {
  id          String     @id @default(cuid())
  jurisdiction String
  ruleNumber  String
  ruleName    String
  description String
  daysToAdd   Int
  daysType    DaysType   @default(CALENDAR)
  triggerEvent String
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  deadlines   Deadline[]

  @@map("court_rules")
}

enum DaysType {
  CALENDAR
  BUSINESS
  COURT
}

model Task {
  id          String      @id @default(cuid())
  title       String
  description String?

  matterId    String?
  matter      Matter?     @relation(fields: [matterId], references: [id])
  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  assigneeId  String?
  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id])

  priority    Priority    @default(MEDIUM)
  status      TaskStatus  @default(TODO)
  dueDate     DateTime?
  completedAt DateTime?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
  CANCELLED
}

// ==================== TIME & BILLING ====================

model TimeEntry {
  id              String       @id @default(cuid())

  matterId        String
  matter          Matter       @relation(fields: [matterId], references: [id])
  userId          String
  user            User         @relation(fields: [userId], references: [id])

  date            DateTime     @db.Date
  hours           Decimal      @db.Decimal(8, 2)
  description     String

  activityCode    String?
  billableStatus  BillableStatus @default(BILLABLE)
  rate            Decimal      @db.Decimal(10, 2)
  amount          Decimal      @db.Decimal(12, 2)

  invoiceId       String?
  invoice         Invoice?     @relation(fields: [invoiceId], references: [id])

  // AI captured
  aiCaptured      Boolean      @default(false)
  aiSource        String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("time_entries")
}

enum BillableStatus {
  BILLABLE
  NON_BILLABLE
  NO_CHARGE
  BILLED
}

model Expense {
  id              String       @id @default(cuid())

  matterId        String
  matter          Matter       @relation(fields: [matterId], references: [id])

  date            DateTime     @db.Date
  description     String
  amount          Decimal      @db.Decimal(10, 2)
  category        ExpenseCategory

  vendor          String?
  receiptPath     String?

  billableStatus  BillableStatus @default(BILLABLE)

  invoiceId       String?
  invoice         Invoice?     @relation(fields: [invoiceId], references: [id])

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("expenses")
}

enum ExpenseCategory {
  FILING_FEE
  COURT_COST
  EXPERT_WITNESS
  DEPOSITION
  TRAVEL
  COPYING
  POSTAGE
  COURIER
  RESEARCH
  OTHER
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique

  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  matterId        String
  matter          Matter        @relation(fields: [matterId], references: [id])

  issueDate       DateTime      @db.Date
  dueDate         DateTime      @db.Date

  subtotal        Decimal       @db.Decimal(10, 2)
  taxRate         Decimal?      @db.Decimal(5, 2)
  taxAmount       Decimal?      @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)

  status          InvoiceStatus @default(DRAFT)

  // LEDES billing
  ledesFormat     Boolean       @default(false)
  ledesExport     String?

  notes           String?

  paidAmount      Decimal       @db.Decimal(10, 2) @default(0)
  paidDate        DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  timeEntries     TimeEntry[]
  expenses        Expense[]
  payments        Payment[]

  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
  WRITTEN_OFF
}

model Payment {
  id              String        @id @default(cuid())

  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  invoiceId       String?
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id])

  amount          Decimal       @db.Decimal(10, 2)
  paymentDate     DateTime      @db.Date
  paymentMethod   PaymentMethod
  referenceNumber String?
  notes           String?

  // Trust account
  trustAccountId  String?
  trustAccount    TrustAccount? @relation(fields: [trustAccountId], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("payments")
}

enum PaymentMethod {
  CHECK
  CREDIT_CARD
  ACH
  WIRE
  CASH
  TRUST_TRANSFER
  OTHER
}

model TrustAccount {
  id              String         @id @default(cuid())
  accountName     String
  accountNumber   String
  bankName        String
  balance         Decimal        @db.Decimal(15, 2) @default(0)
  ioltaAccount    Boolean        @default(true)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  transactions    TrustTransaction[]
  payments        Payment[]

  @@map("trust_accounts")
}

model TrustTransaction {
  id              String         @id @default(cuid())
  trustAccountId  String
  trustAccount    TrustAccount   @relation(fields: [trustAccountId], references: [id])

  type            TransactionType
  amount          Decimal        @db.Decimal(10, 2)
  description     String
  referenceNumber String?

  transactionDate DateTime       @db.Date
  createdAt       DateTime       @default(now())

  @@map("trust_transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  INTEREST
  FEE
}

// ==================== COURT FILING ====================

model CourtFiling {
  id              String        @id @default(cuid())

  matterId        String
  matter          Matter        @relation(fields: [matterId], references: [id])

  documentName    String
  documentType    DocumentCategory
  filingType      FilingType

  courtName       String
  caseNumber      String?

  filingDate      DateTime?     @db.Date
  dueDate         DateTime?     @db.Date

  status          FilingStatus  @default(DRAFT)

  // E-filing
  eFilingId       String?
  eFilingStatus   String?
  eFilingReceipt  String?

  // Fees
  filingFee       Decimal?      @db.Decimal(10, 2)
  feePaid         Boolean       @default(false)

  // Service
  serviceRequired Boolean       @default(false)
  serviceStatus   ServiceStatus?
  serviceDate     DateTime?
  proofOfService  String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("court_filings")
}

enum FilingType {
  INITIAL
  RESPONSE
  MOTION
  BRIEF
  EXHIBIT
  ORDER
  NOTICE
  OTHER
}

enum FilingStatus {
  DRAFT
  READY
  SUBMITTED
  ACCEPTED
  REJECTED
  FILED
}

enum ServiceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

// ==================== COMMUNICATION ====================

model Message {
  id              String        @id @default(cuid())

  senderId        String?
  sender          User?         @relation(fields: [senderId], references: [id])
  clientId        String?
  client          Client?       @relation(fields: [clientId], references: [id])

  type            MessageType
  subject         String?
  content         String        @db.Text

  isSecure        Boolean       @default(true)
  isRead          Boolean       @default(false)
  readAt          DateTime?

  // For emails
  fromEmail       String?
  toEmail         String?
  cc              String?
  bcc             String?

  // AI features
  aiDrafted       Boolean       @default(false)
  aiSuggestions   String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("messages")
}

enum MessageType {
  EMAIL
  PORTAL_MESSAGE
  SMS
  INTERNAL
}

model CallLog {
  id              String        @id @default(cuid())

  userId          String
  user            User          @relation(fields: [userId], references: [id])

  callerName      String
  callerPhone     String
  callType        CallType

  duration        Int?
  notes           String?

  matterId        String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("call_logs")
}

enum CallType {
  INCOMING
  OUTGOING
  MISSED
  VOICEMAIL
}

model Notification {
  id              String        @id @default(cuid())

  userId          String
  user            User          @relation(fields: [userId], references: [id])

  type            NotificationType
  title           String
  message         String

  isRead          Boolean       @default(false)
  readAt          DateTime?

  link            String?

  createdAt       DateTime      @default(now())

  @@map("notifications")
}

enum NotificationType {
  DEADLINE
  TASK
  MESSAGE
  CALENDAR
  DOCUMENT
  BILLING
  SYSTEM
}

// ==================== AI FEATURES ====================

model AIRequest {
  id              String        @id @default(cuid())

  userId          String
  user            User          @relation(fields: [userId], references: [id])
  matterId        String?
  matter          Matter?       @relation(fields: [matterId], references: [id])

  type            AIRequestType
  prompt          String        @db.Text
  response        String?       @db.Text

  status          AIRequestStatus @default(PENDING)
  tokensUsed      Int?
  processingTime  Int?

  createdAt       DateTime      @default(now())
  completedAt     DateTime?

  @@map("ai_requests")
}

enum AIRequestType {
  DOCUMENT_DRAFT
  CONTRACT_REVIEW
  LEGAL_RESEARCH
  DEPOSITION_SUMMARY
  CONFLICT_CHECK
  TIME_ENTRY
  CLIENT_INTAKE
  DOCUMENT_SUMMARY
  DEADLINE_CALC
  EMAIL_DRAFT
  DISCOVERY
}

enum AIRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
